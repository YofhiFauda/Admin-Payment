# ═══════════════════════════════════════════════════════════════════
#  PRODUCTION ENVIRONMENT CONFIGURATION
#  ⚠️  CRITICAL: Ganti semua nilai dengan credentials production yang aman
# ═══════════════════════════════════════════════════════════════════

# ─── Application ───────────────────────────────────────────────────
APP_NAME="WHUSNET Admin Payment"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://admin-payment.whusnet.com

# ─── N8N Webhook ───────────────────────────────────────────────────
N8N_WEBHOOK=https://n8nwhusnet.connexa.net.id
N8N_SECRET=mySuperSecretKey123

# ─── Horizon ───────────────────────────────────────────────────────
HORIZON_PREFIX=whusnet_horizon:
HORIZON_DOMAIN=yourdomain.com

# ─── Localization ──────────────────────────────────────────────────
APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID
APP_TIMEZONE=Asia/Jakarta

APP_MAINTENANCE_DRIVER=file

# ─── Logging Configuration ─────────────────────────────────────────
# Log channel: stack (multiple channels), daily, single, slack, syslog
# LOG_CHANNEL=stack
# LOG_STACK=daily,error,slack
# LOG_STACK=daily,error, stderr

# Log levels: debug, info, notice, warning, error, critical, alert, emergency
# Production: warning (only warnings and above)
# Staging: info (informational and above)
# Development: debug (everything)
LOG_LEVEL=warning
LOG_LEVEL_OCR=info
LOG_LEVEL_QUEUE=info

# Daily log retention (days)
LOG_DAILY_DAYS=30

# Deprecations logging
LOG_DEPRECATIONS_CHANNEL=null
LOG_DEPRECATIONS_TRACE=false

# Slack notifications for critical errors
# LOG_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
# LOG_SLACK_USERNAME="WHUSNET Production Alert"
# LOG_SLACK_EMOJI=":rotating_light:"
# LOG_SLACK_LEVEL=critical

# Papertrail (optional - cloud logging service)
# PAPERTRAIL_URL=logs.papertrailapp.com
# PAPERTRAIL_PORT=12345

# ─── Gemini Rate Limit Settings ────────────────────────────────────
# Free tier: 15 RPM → set 12 (safety buffer)
# Pro tier: 60 RPM → set 48
GEMINI_RPM_LIMIT=60
GEMINI_COOLDOWN_SECONDS=5


# ─── Image Compression (OCR Pre-processing) ──────────────────
COMPRESSION_MAX_SIZE=1048576
COMPRESSION_INITIAL_QUALITY=85
COMPRESSION_MIN_QUALITY=75
COMPRESSION_ENABLED=true
UPLOAD_MAX_SIZE=10240

# ─── GitHub MCP Settings (Optional) ────────────────────────────────
GITHUB_PERSONAL_ACCESS_TOKEN=

# ─── Security ──────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

# ─── Logging ───────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=daily,stderr,error
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# Slack webhook untuk critical errors
# LOG_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ─── Database ──────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=admin_payment
DB_USERNAME=root
DB_PASSWORD=
# DB_SSLMODE=require

# ─── Cache & Session ───────────────────────────────────────────────
CACHE_DRIVER=redis
CACHE_STORE=redis

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=admin-payment.whusnet.com

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

# ─── Redis ─────────────────────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=
REDIS_PORT=6379
REDIS_PREFIX=whusnet_prod:

# Redis connection settings
REDIS_MAX_RETRIES=3
REDIS_BACKOFF_ALGORITHM=decorrelated_jitter
REDIS_BACKOFF_BASE=100
REDIS_BACKOFF_CAP=1000

# ─── Queue Settings ────────────────────────────────────────────────
OCR_MAX_QUEUE_SIZE=200
REDIS_QUEUE_RETRY_AFTER=90

# ─── Mail ──────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@yourdomain.com"
MAIL_FROM_NAME="${APP_NAME}"

# ─── AWS (Optional) ────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ─── Laravel Reverb (WebSocket) ────────────────────────────────────
# Backend settings
REVERB_APP_ID=893247
REVERB_APP_KEY=whusnet_reverb_key_123
REVERB_APP_SECRET=whusnet_reverb_secret_123
REVERB_HOST=0.0.0.0
# Use 443 if proxied via Nginx SSL (standard production setup)
REVERB_PORT=8081
REVERB_SCHEME=https

# Frontend settings (untuk browser)
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
# VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_HOST=admin-payment.whusnet.com
VITE_REVERB_PORT=443
VITE_REVERB_SCHEME=https

# ─── Monitoring (Optional) ─────────────────────────────────────────
# Sentry for error tracking
# SENTRY_LARAVEL_DSN=https://your-sentry-dsn@sentry.io/project-id

# New Relic APM
# NEWRELIC_LICENSE_KEY=
# NEWRELIC_APPNAME="${APP_NAME}"

# ─── Telegram Bot (Optional) ───────────────────────────────────────
TELEGRAM_BOT_TOKEN=8561621292:AAGPw_flxNF6z8egKaICusUwWAR5Neleba0
# TELEGRAM_WEBHOOK_URL=https://yourdomain.com/api/telegram/webhook

# ─── Telescope (Debugging Tool) ────────────────────────────────────
# ⚠️  DISABLE di production untuk performa & keamanan
TELESCOPE_ENABLED=false

# ─── Laravel Pulse (Monitoring) ────────────────────────────────────
# ✅ Production-ready monitoring dashboard
PULSE_ENABLED=true
PULSE_PATH=pulse
PULSE_DOMAIN=admin-payment.whusnet.com

# Pulse Storage
PULSE_STORAGE_DRIVER=database
PULSE_DB_CONNECTION=mysql

# Pulse Ingest
PULSE_INGEST_DRIVER=storage
PULSE_INGEST_BUFFER=5000

# Pulse Recorders (enable/disable specific metrics)
PULSE_CACHE_INTERACTIONS_ENABLED=true
PULSE_EXCEPTIONS_ENABLED=true
PULSE_QUEUES_ENABLED=true
PULSE_SERVERS_ENABLED=true
PULSE_SLOW_JOBS_ENABLED=true
PULSE_SLOW_JOBS_THRESHOLD=1000
PULSE_SLOW_OUTGOING_REQUESTS_ENABLED=true
PULSE_SLOW_OUTGOING_REQUESTS_THRESHOLD=1000
PULSE_SLOW_QUERIES_ENABLED=true
PULSE_SLOW_QUERIES_THRESHOLD=1000
PULSE_SLOW_REQUESTS_ENABLED=true
PULSE_SLOW_REQUESTS_THRESHOLD=1000
PULSE_USER_JOBS_ENABLED=true
PULSE_USER_REQUESTS_ENABLED=true

# ─── Laravel Log Viewer (GUI for Logs) ─────────────────────────────
# ✅ Beautiful GUI for viewing logs (like Telescope but production-safe)
LOG_VIEWER_PATH=log-viewer
LOG_VIEWER_BACK_URL=/dashboard
LOG_VIEWER_MAX_SIZE=104857600
LOG_VIEWER_TIMEZONE=Asia/Jakarta

# ─── Rate Limiting ─────────────────────────────────────────────────
THROTTLE_API_LIMIT=60
THROTTLE_OCR_LIMIT=10

# ─── Asset URL (CDN) ───────────────────────────────────────────────
# ASSET_URL=https://cdn.yourdomain.com

# ─── Trusted Proxies ───────────────────────────────────────────────
# Jika di belakang load balancer/proxy
# TRUSTED_PROXIES=*
