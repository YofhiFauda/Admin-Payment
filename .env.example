REVERB_APP_KEY=whusnet_reverb_key_123
REVERB_APP_SECRET=whusnet_reverb_secret_123
REVERB_HOST=reverb
REVERB_PORT=8081
REVERB_SCHEME=http

# Frontend/browser connection
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST=admin-payment.whusnet.com
