# ═══════════════════════════════════════════════════════════════════
#  PRODUCTION ENVIRONMENT CONFIGURATION - EXAMPLE
#  ⚠️  Ganti semua nilai dengan credentials production yang aman
# ═══════════════════════════════════════════════════════════════════

# ─── Coolify / Service Discovery ──────────────────────────────────
SERVICE_FQDN_NGINX=admin-payment.whusnet.com
SERVICE_URL_NGINX=https://admin-payment.whusnet.com

# ─── Application ───────────────────────────────────────────────────
APP_NAME="WHUSNET Admin Payment"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://admin-payment.whusnet.com
APP_DOMAIN=admin-payment.whusnet.com
APP_TIMEZONE=Asia/Jakarta
APP_LOCALE=id
APP_FALLBACK_LOCALE=id

# ─── Database ──────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=admin_payment
DB_USERNAME=root
DB_PASSWORD=

# ─── Redis ─────────────────────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_USERNAME=default
REDIS_PREFIX=whusnet_prod:
REDIS_MAX_RETRIES=3

# ─── Cache & Session ───────────────────────────────────────────────
# ⚠️ Gunakan Redis untuk performa terbaik di production
CACHE_DRIVER=redis
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
# ⚠️ WAJIB null di balik reverse proxy agar cookie tidak ditolak
SESSION_DOMAIN=null
# ⚠️ WAJIB false jika HTTPS di-handle oleh Nginx/Proxy (Coolify)
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

# ─── Queue & Broadcast ─────────────────────────────────────────────
QUEUE_CONNECTION=redis
REDIS_QUEUE_RETRY_AFTER=90
BROADCAST_CONNECTION=reverb

# ─── Laravel Reverb (WebSocket) ────────────────────────────────────
# Backend settings (Koneksi Internal Antar Container)
REVERB_APP_ID=893247
REVERB_APP_KEY=whusnet_reverb_key_123
REVERB_APP_SECRET=whusnet_reverb_secret_123
REVERB_HOST=reverb
REVERB_PORT=8081
REVERB_SCHEME=http

# Frontend settings (untuk browser)
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST=admin-payment.whusnet.com
VITE_REVERB_PORT=443
VITE_REVERB_SCHEME=https

# ─── Horizon ───────────────────────────────────────────────────────
HORIZON_PREFIX=whusnet_horizon:
HORIZON_DOMAIN=admin-payment.whusnet.com

# ─── Logging Configuration ─────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=daily,stderr,error
LOG_LEVEL=warning
LOG_LEVEL_OCR=info
LOG_LEVEL_QUEUE=info
LOG_DAILY_DAYS=30
LOG_DEPRECATIONS_CHANNEL=null

# ─── Telegram Bot ──────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_GROUP_MONITORING_ID=

# ─── Gemini & Integrations ─────────────────────────────────────────
N8N_WEBHOOK=
N8N_SECRET=
GEMINI_RPM_LIMIT=60
GEMINI_COOLDOWN_SECONDS=5

# ─── Filesystem & Uploads ──────────────────────────────────────────
FILESYSTEM_DISK=local
UPLOAD_MAX_SIZE=10240
OCR_MAX_QUEUE_SIZE=200
COMPRESSION_ENABLED=true
COMPRESSION_MAX_SIZE=1048576
COMPRESSION_INITIAL_QUALITY=85
COMPRESSION_MIN_QUALITY=75
BCRYPT_ROUNDS=12

# ─── Security & Proxy ──────────────────────────────────────────────
TRUSTED_PROXIES=*

# ─── Laravel Pulse (Monitoring) ────────────────────────────────────
PULSE_ENABLED=true
PULSE_PATH=pulse
PULSE_STORAGE_DRIVER=database
PULSE_INGEST_DRIVER=redis
PULSE_REDIS_CONNECTION=pulse
PULSE_DB_CONNECTION=pulse

# Detail Database Khusus Pulse (Gunakan DB yang sama atau terpisah)
PULSE_DB_HOST=
PULSE_DB_PORT=3306
PULSE_DB_DATABASE=
PULSE_DB_USERNAME=
PULSE_DB_PASSWORD=

# Pulse Recorders
PULSE_CACHE_INTERACTIONS_ENABLED=true
PULSE_EXCEPTIONS_ENABLED=true
PULSE_QUEUES_ENABLED=true
PULSE_SERVERS_ENABLED=false
PULSE_SLOW_JOBS_ENABLED=true
PULSE_SLOW_JOBS_THRESHOLD=1000
PULSE_SLOW_OUTGOING_REQUESTS_ENABLED=true
PULSE_SLOW_OUTGOING_REQUESTS_THRESHOLD=1000
PULSE_SLOW_QUERIES_ENABLED=true
PULSE_SLOW_QUERIES_THRESHOLD=1000
PULSE_SLOW_REQUESTS_ENABLED=true
PULSE_SLOW_REQUESTS_THRESHOLD=1000
PULSE_USER_JOBS_ENABLED=true
PULSE_USER_REQUESTS_ENABLED=true

# ─── Laravel Log Viewer ────────────────────────────────────────────
LOG_VIEWER_PATH=log-viewer
LOG_VIEWER_BACK_URL=/dashboard
LOG_VIEWER_MAX_SIZE=104857600
LOG_VIEWER_TIMEZONE=Asia/Jakarta

# ─── Livewire ──────────────────────────────────────────────────────
LIVEWIRE_UPDATE_PATH=livewire/update

# ─── Rate Limiting ─────────────────────────────────────────────────
THROTTLE_API_LIMIT=60
THROTTLE_OCR_LIMIT=10