N8N_WEBHOOK=https://ropier-raphael-unsalacious.ngrok-free.dev/webhook/upload-foto
N8N_SECRET=mySuperSecretKey123

# VIEW_COMPILED_PATH=/tmp/views
# VIEW_COMPILED_PATH=/var/www/storage/framework/views

HORIZON_PREFIX=whusnet_horizon
HORIZON_DOMAIN=null

APP_LOCALE=en   
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database


# ─── ✅ BARU: Gemini Rate Limit Settings ─────────────────────
# Free tier Gemini:  15 RPM → set ke 12 (80% safety buffer)
# Pro tier Gemini:   60 RPM → set ke 48
GEMINI_RPM_LIMIT=12
GEMINI_COOLDOWN_SECONDS=5

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=db
# DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=admin-payment
DB_USERNAME=root
DB_PASSWORD=root
DB_SSLMODE=disable


# ─── ✅ BARU: Cache & Session ─────────────────────────────────
CACHE_DRIVER=redis

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=password1234
REDIS_PORT=6379

# ─── ✅ BARU: Overload Protection ────────────────────────────
# Max job di antrian OCR sekaligus (500 user → 200 cukup)
OCR_MAX_QUEUE_SIZE=200

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ─── ✅ BARU: Laravel Reverb ─────────────────────────────────
# ─── Untuk BACKEND (Reverb Server) ─────────────────────────────
# Reverb BINDING lokal (tetap localhost, karena server jalan di sini)
REVERB_APP_ID=893247
REVERB_APP_KEY=whusnet_reverb_key_123
REVERB_APP_SECRET=whusnet_reverb_secret_123
REVERB_HOST=reverb
REVERB_PORT=8081
REVERB_SCHEME=http


# ─── Untuk FRONTEND (Browser/User) ─────────────────────────────
# Frontend CONNECT via Cloudflared (harus HTTPS/WSS)
# cloudflared tunnel --url http://localhost:8081
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
# VITE_REVERB_HOST=pointer-assessment-premiere-pushing.trycloudflare.com
# VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_PORT=443
# VITE_REVERB_SCHEME="${REVERB_SCHEME}"
VITE_REVERB_SCHEME=https
