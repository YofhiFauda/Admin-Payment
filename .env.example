APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
# cloudflared tunnel --url http://localhost:8000
# APP_URL=https://exit-timeline-browser-jesse.trycloudflare.com
N8N_WEBHOOK=https://ropier-raphael-unsalacious.ngrok-free.dev/webhook/upload-foto
N8N_SECRET=mySuperSecretKey123

# VIEW_COMPILED_PATH=/tmp/views
# VIEW_COMPILED_PATH=/var/www/storage/framework/views

HORIZON_PREFIX=whusnet_horizon
HORIZON_DOMAIN=null
# Horizon Basic Auth (untuk production, bypass cookie issue)
HORIZON_USERNAME=admin
HORIZON_PASSWORD=secret

APP_LOCALE=en   
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database


# ─── ✅ BARU: Gemini Rate Limit Settings ─────────────────────
# Free tier Gemini:  15 RPM → set ke 12 (80% safety buffer)
# Pro tier Gemini:   60 RPM → set ke 48
GEMINI_RPM_LIMIT=12
GEMINI_COOLDOWN_SECONDS=5

# ─── ✅ BARU: GitHub MCP Settings ──────────────────────────────
# Token: https://github.com/settings/tokens?type=beta
# Permissions: Read access (Metadata, Contents), Read/Write (Issues, Pull Requests)
GITHUB_PERSONAL_ACCESS_TOKEN=

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
