# ═══════════════════════════════════════════════════════════════════
#  WHUSNET ADMIN PAYMENT - PRODUCTION ENVIRONMENT
#  Template untuk Domain Sendiri
# ═══════════════════════════════════════════════════════════════════
#
#  INSTRUKSI:
#  1. Copy file ini ke .env.production
#  2. Ganti semua <YOUR_DOMAIN> dengan domain Anda
#  3. Ganti semua <YOUR_*> dengan nilai yang sesuai
#  4. Rebuild frontend: npm run build
#  5. Clear caches: php artisan config:clear && php artisan cache:clear
#  6. Restart: docker-compose restart
#
# ═══════════════════════════════════════════════════════════════════

# ─── Coolify / Service Discovery ──────────────────────────────────
# Ganti dengan domain Anda, contoh: admin.whusnet.com
SERVICE_FQDN_APP=<YOUR_DOMAIN>
SERVICE_URL_APP=https://<YOUR_DOMAIN>
SERVICE_FQDN_NGINX=<YOUR_DOMAIN>
SERVICE_URL_NGINX=https://<YOUR_DOMAIN>

# WebSocket subdomain (optional, bisa sama dengan domain utama)
# Contoh: ws.admin.whusnet.com atau admin.whusnet.com
SERVICE_FQDN_REVERB=<YOUR_WS_DOMAIN>
SERVICE_URL_REVERB=https://<YOUR_WS_DOMAIN>

# ─── Application ───────────────────────────────────────────────────
APP_NAME="WHUSNET Admin Payment"
APP_ENV=production
APP_KEY=<YOUR_APP_KEY>  # Generate dengan: php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://<YOUR_DOMAIN>
APP_DOMAIN=<YOUR_DOMAIN>  # Optional, bisa dikosongkan
APP_TIMEZONE=Asia/Jakarta
APP_LOCALE=id
APP_FALLBACK_LOCALE=id

# ─── Database ──────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=<YOUR_DB_HOST>  # Contoh: mysql atau IP database server
DB_PORT=3306
DB_DATABASE=<YOUR_DB_NAME>
DB_USERNAME=<YOUR_DB_USER>
DB_PASSWORD=<YOUR_DB_PASSWORD>

# ─── Redis ─────────────────────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=<YOUR_REDIS_HOST>  # Contoh: redis atau IP redis server
REDIS_PORT=6379
REDIS_PASSWORD=<YOUR_REDIS_PASSWORD>
REDIS_USERNAME=default
REDIS_PREFIX=whusnet_prod:
REDIS_MAX_RETRIES=3

# ─── Cache & Session ───────────────────────────────────────────────
CACHE_DRIVER=redis
CACHE_STORE=redis

# Session configuration (PENTING untuk Log Viewer)
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null  # Atau .<YOUR_ROOT_DOMAIN> untuk allow subdomain

# HTTPS settings (PENTING untuk production)
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

# ─── Queue & Broadcast ─────────────────────────────────────────────
QUEUE_CONNECTION=redis
REDIS_QUEUE_RETRY_AFTER=90
BROADCAST_CONNECTION=reverb

# ─── Laravel Reverb (WebSocket) ────────────────────────────────────
# Internal container connection (JANGAN DIUBAH)
REVERB_APP_ID=893247
REVERB_APP_KEY=whusnet_reverb_key_123
REVERB_APP_SECRET=whusnet_reverb_secret_123
REVERB_HOST=reverb
REVERB_PORT=8081
REVERB_SCHEME=http

# Frontend/browser connection (UBAH SESUAI DOMAIN)
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST=<YOUR_WS_DOMAIN>  # Contoh: ws.admin.whusnet.com atau admin.whusnet.com
VITE_REVERB_PORT=443
VITE_REVERB_SCHEME=https

# ─── Horizon ───────────────────────────────────────────────────────
HORIZON_PREFIX=whusnet_horizon:
HORIZON_DOMAIN=null  # Atau subdomain terpisah jika diperlukan

# ─── Logging ───────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=daily,stderr,error
LOG_LEVEL=warning
LOG_LEVEL_OCR=info
LOG_LEVEL_QUEUE=info
LOG_DAILY_DAYS=30
LOG_DEPRECATIONS_CHANNEL=null

# ─── Telegram Bot ──────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=<YOUR_TELEGRAM_BOT_TOKEN>
TELEGRAM_GROUP_MONITORING_ID=<YOUR_TELEGRAM_GROUP_ID>

# ─── Integrations ──────────────────────────────────────────────────
N8N_WEBHOOK=<YOUR_N8N_WEBHOOK_URL>
N8N_SECRET=<YOUR_N8N_SECRET>

# ─── Gemini ────────────────────────────────────────────────────────
GEMINI_RPM_LIMIT=60
GEMINI_COOLDOWN_SECONDS=5

# ─── Filesystem & Uploads ──────────────────────────────────────────
FILESYSTEM_DISK=local
UPLOAD_MAX_SIZE=10240

# OCR Queue
OCR_MAX_QUEUE_SIZE=200

# Compression
COMPRESSION_ENABLED=true
COMPRESSION_MAX_SIZE=1048576
COMPRESSION_INITIAL_QUALITY=85
COMPRESSION_MIN_QUALITY=75

# Security
BCRYPT_ROUNDS=12
TRUSTED_PROXIES=*

# ─── Laravel Pulse ─────────────────────────────────────────────────
PULSE_ENABLED=true
PULSE_PATH=pulse
PULSE_STORAGE_DRIVER=database
PULSE_INGEST_DRIVER=redis
PULSE_REDIS_CONNECTION=pulse
PULSE_DB_CONNECTION=pulse

# Pulse Database (biasanya sama dengan DB utama)
PULSE_DB_HOST=<YOUR_DB_HOST>
PULSE_DB_PORT=3306
PULSE_DB_DATABASE=<YOUR_DB_NAME>
PULSE_DB_USERNAME=<YOUR_DB_USER>
PULSE_DB_PASSWORD=<YOUR_DB_PASSWORD>

# Pulse Redis (bisa sama dengan Redis utama atau terpisah)
PULSE_REDIS_HOST=<YOUR_PULSE_REDIS_HOST>
PULSE_REDIS_PORT=6379
PULSE_REDIS_USERNAME=default
PULSE_REDIS_PASSWORD=<YOUR_PULSE_REDIS_PASSWORD>

# Pulse Recorders
PULSE_CACHE_INTERACTIONS_ENABLED=true
PULSE_EXCEPTIONS_ENABLED=true
PULSE_QUEUES_ENABLED=true
PULSE_SERVERS_ENABLED=true

PULSE_SLOW_JOBS_ENABLED=true
PULSE_SLOW_JOBS_THRESHOLD=1000

PULSE_SLOW_OUTGOING_REQUESTS_ENABLED=true
PULSE_SLOW_OUTGOING_REQUESTS_THRESHOLD=1000

PULSE_SLOW_QUERIES_ENABLED=true
PULSE_SLOW_QUERIES_THRESHOLD=1000

PULSE_SLOW_REQUESTS_ENABLED=true
PULSE_SLOW_REQUESTS_THRESHOLD=1000

PULSE_USER_JOBS_ENABLED=true
PULSE_USER_REQUESTS_ENABLED=true

# ─── Laravel Log Viewer ────────────────────────────────────────────
LOG_VIEWER_PATH=log-viewer
LOG_VIEWER_BACK_URL=/dashboard
LOG_VIEWER_MAX_SIZE=104857600
LOG_VIEWER_TIMEZONE=Asia/Jakarta

# ─── Livewire ──────────────────────────────────────────────────────
LIVEWIRE_UPDATE_PATH=livewire/update

# ─── Rate Limiting ─────────────────────────────────────────────────
THROTTLE_API_LIMIT=60
THROTTLE_OCR_LIMIT=10

# ─── Optional Features ─────────────────────────────────────────────
TELESCOPE_ENABLED=false
