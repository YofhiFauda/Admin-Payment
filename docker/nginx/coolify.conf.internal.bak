# ═══════════════════════════════════════════════════════════════════
#  NGINX Configuration for Coolify (Internal Proxy)
#  Traefik handles SSL, domain routing, and HSTS
#
#  STRATEGI AKSES:
#  ┌─────────────────────────────────────────────────┬──────────────────────────┐
#  │  Path                                           │  Akses                   │
#  ├─────────────────────────────────────────────────┼──────────────────────────┤
#  │  /app/*  (WebSocket Reverb)                     │  PUBLIC (auth Pusher)    │
#  │  /broadcasting/auth                             │  PUBLIC (auth Laravel)   │
#  │  /api/telegram/webhook                          │  PUBLIC (Telegram)       │
#  │  /api/ai/auto-fill, /api/payment/verify         │  PUBLIC (n8n)            │
#  │  /api/ai/*/status  (polling OCR)                │  PUBLIC (browser)        │
#  │  /api/*  (lainnya)                              │  IP Internal saja        │
#  │  /login                                         │  IP Internal saja        │
#  │  /*  (aplikasi utama)                           │  IP Internal saja        │
#  │  /up, /health                                   │  PUBLIC (healthcheck)    │
#  └─────────────────────────────────────────────────┴──────────────────────────┘
#
#  KENAPA /app/ & /broadcasting/auth harus PUBLIC?
#  ─ WebSocket (/app/) pakai autentikasi Pusher Protocol bawaan Reverb.
#    Tidak perlu IP filter karena koneksi tetap ditolak jika app_key salah.
#  ─ /broadcasting/auth dipanggil browser user yang sudah LOGIN (ada session
#    cookie). Keamanannya dari sesi Laravel, bukan IP. Memblokir via IP
#    akan mematikan fitur real-time untuk user di luar kantor / IP dinamis.
#
#  BUG YANG DIPERBAIKI DARI VERSI SEBELUMNYA:
#  1. /app/ punya "allow 165.99.202.250/30; deny all" → user luar tidak bisa
#     konek WebSocket walau sudah authenticated. Dihapus.
#  2. /broadcasting/auth punya "allow all" TAPI ditulis SETELAH location /
#     yang punya "deny all". Nginx exact match (=) seharusnya menang atas
#     prefix (/), tapi karena ada location ~ di antaranya, evaluasi bisa salah.
#     Solusi: hapus allow/deny dari /broadcasting/auth (langsung pass ke PHP).
#  3. IP range /30 terlalu sempit (hanya 4 IP). Diperluas ke /24.
#  4. Telegram webhook digabung ke regex umum webhook → pisahkan ke exact match.
# ═══════════════════════════════════════════════════════════════════

# WebSocket upgrade map
map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}

# Rate limiting zones
limit_req_zone $binary_remote_addr zone=general:10m rate=10r/s;
limit_req_zone $binary_remote_addr zone=api:10m     rate=60r/m;
limit_req_zone $binary_remote_addr zone=polling:10m rate=120r/m;
limit_req_zone $binary_remote_addr zone=login:10m   rate=5r/m;
limit_req_zone $binary_remote_addr zone=dashboard:10m rate=30r/m;  # Dashboard endpoints
limit_conn_zone $binary_remote_addr zone=addr:10m;

# Upstream PHP-FPM
upstream php-fpm {
    server app:9000;
    keepalive 32;
}

# Catatan: upstream Reverb tidak dideklarasikan di sini.
# Gunakan resolver Docker + variable $reverb_upstream di dalam location /app/
# untuk menghindari masalah resolusi IPv6 Docker DNS.

server {
    listen 80;
    server_name _;

    # ─── Real IP dari Traefik/Coolify (bukan IP Docker internal) ───
    # Traefik meneruskan IP asli client via X-Forwarded-For
    real_ip_header    X-Forwarded-For;
    real_ip_recursive on;

    # Percayai range IP jaringan internal Docker/Coolify
    set_real_ip_from 10.0.0.0/8;
    set_real_ip_from 172.16.0.0/12;
    set_real_ip_from 192.168.0.0/16;

    root  /var/www/public;
    index index.php index.html;

    # Security Headers (Minimal, Traefik handles the rest)
    add_header X-Frame-Options        "SAMEORIGIN"    always;
    add_header X-Content-Type-Options "nosniff"       always;
    add_header X-XSS-Protection       "1; mode=block" always;

    # Client settings
    client_max_body_size    64M;
    client_body_buffer_size 128k;

    # Timeouts
    client_body_timeout   12;
    client_header_timeout 12;
    keepalive_timeout     15;
    send_timeout          10;

    # Connection limiting
    limit_conn addr 10;
    limit_req_status 429;

    # Gzip compression
    gzip            on;
    gzip_vary       on;
    gzip_proxied    any;
    gzip_comp_level 6;
    gzip_types
        text/plain text/css text/xml text/javascript
        application/json application/javascript application/xml+rss
        application/rss+xml font/truetype font/opentype
        application/vnd.ms-fontobject image/svg+xml application/xhtml+xml
        application/x-font-ttf application/x-font-opentype;

    # Logging
    access_log /var/log/nginx/access.log combined buffer=32k flush=5s;
    error_log  /var/log/nginx/error.log  warn;

    # Hide nginx version
    server_tokens off;

    # ─────────────────────────────────────────────────────────────
    #  STATIC ASSETS — Public, tanpa IP restriction
    #  Ditulis pertama agar tidak "terblokir" oleh location / di bawah
    # ─────────────────────────────────────────────────────────────

    location ~* \.(jpg|jpeg|png|gif|ico|css|js|svg|woff|woff2|ttf|eot|webp|avif|map)$ {
        expires 1y;
        add_header Cache-Control "public, immutable";
        access_log off;
        try_files $uri =404;
    }

    # Storage symlink (file upload publik)
    location /storage/ {
        alias /var/www/storage/app/public/;
        expires 1y;
        add_header Cache-Control "public, max-age=31536000, immutable";
        access_log off;
        try_files $uri =404;
    }

    # Vite build assets
    location /build/ {
        expires 1y;
        add_header Cache-Control "public, immutable";
        access_log off;
        try_files $uri =404;
    }

    # Deny dotfiles (.env, .git, dll)
    location ~ /\. {
        deny all;
        access_log    off;
        log_not_found off;
    }

    # ─────────────────────────────────────────────────────────────
    #  HEALTH CHECKS — Selalu public (dipakai Coolify/Docker probe)
    # ─────────────────────────────────────────────────────────────

    location = /up {
        allow all;
        access_log off;
        return 200 "OK\n";
        add_header Content-Type text/plain;
    }

    location = /health {
        allow all;
        access_log off;
        return 200 "OK\n";
        add_header Content-Type text/plain;
    }

    # ─────────────────────────────────────────────────────────────
    #  WEBSOCKET REVERB — Public (autentikasi via Pusher Protocol)
    #
    #  ⚠️  JANGAN tambahkan allow/deny di sini.
    #  Reverb menolak koneksi jika app_key tidak cocok — keamanan
    #  sudah ditangani di level protokol Pusher, bukan IP.
    #  Memblokir via IP akan mematikan real-time untuk semua user
    #  yang berada di luar IP kantor (termasuk /broadcasting/auth
    #  yang men-trigger koneksi ini).
    # ─────────────────────────────────────────────────────────────



    location /app/ {
        resolver 127.0.0.11 ipv6=off valid=10s;
        set $reverb_upstream http://reverb:8081;
        proxy_pass $reverb_upstream;
        proxy_http_version 1.1;

        proxy_set_header Upgrade    $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_set_header Host       $host;

        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $http_x_forwarded_proto;
        proxy_set_header X-Forwarded-Host  $host;

        proxy_connect_timeout 60s;
        proxy_send_timeout    60s;
        proxy_read_timeout    300s;  # WS bisa idle lama, jangan terlalu singkat

        proxy_cache_bypass $http_upgrade;
        proxy_buffering    off;
    }

    # ─────────────────────────────────────────────────────────────
    #  BROADCASTING AUTH — Public (autentikasi via Laravel Session)
    #
    #  ⚠️  JANGAN tambahkan allow/deny di sini.
    #  Endpoint ini dipanggil oleh Laravel Echo di browser user yang
    #  sudah LOGIN (ada session cookie). IP user bisa dinamis / di
    #  luar kantor. Keamanan dijamin sesi Laravel + CSRF, bukan IP.
    #
    #  FIX dari versi .bak sebelumnya:
    #  Versi lama punya "allow all" tapi tetap error karena ordering
    #  location block salah. Sekarang tidak perlu allow/deny sama sekali.
    # ─────────────────────────────────────────────────────────────

    location = /broadcasting/auth {
        allow all;
        try_files $uri /index.php?$query_string;
    }

    # ─────────────────────────────────────────────────────────────
    #  WEBHOOK EXTERNAL — Public (n8n, Telegram, OCR callbacks)
    #
    #  Server eksternal memanggil endpoint ini secara langsung.
    #  Tidak mungkin membatasi dengan IP kantor.
    #  Keamanan: X-SECRET header (n8n) dan token resmi Telegram.
    # ─────────────────────────────────────────────────────────────


    # Telegram webhook
    # (IP resmi Telegram: 91.108.0.0/16, 149.154.0.0/16 — opsional whitelist di sini)
    location = /api/telegram/webhook {
        allow all;
        try_files $uri /index.php?$query_string;
    }

    # Status polling OCR — browser user menunggu hasil proses AI
    # Ubah menjadi (hilangkan slash sebelum kurung kurawal penutup):
    # OCR callback dari n8n.
    # Wajib public karena n8n memanggil dari IP eksternal, keamanan tetap lewat X-SECRET.
  location ~ ^/api/ai/(auto-fill|auto-fil)$ {
      allow all;
      limit_req zone=polling burst=60 nodelay;
      try_files $uri /index.php?$query_string;
  }

  location ~ ^/api/ai/(auto-fill/status|ai-status)(?:/|$) {
      allow all;
      limit_req zone=polling burst=60 nodelay;
      try_files $uri /index.php?$query_string;
  }

    
    location = /api/payment/verify {
        allow all;
        limit_req zone=polling burst=60 nodelay;
        try_files $uri /index.php?$query_string;
    }

    # Horizon dashboard — auth tetap ditangani Laravel Horizon::auth + session.
    # Jangan dibatasi IP di nginx agar admin/owner di luar IP kantor tidak 503/403.
    location ~ ^/horizon(?:/|$) {
        allow all;
        limit_req zone=api burst=30 nodelay;
        try_files $uri /index.php?$query_string;
    }

    # ─────────────────────────────────────────────────────────────
    #  API INTERNAL — Hanya IP kantor / jaringan internal
    #
    #  FIX dari versi .bak: range diperluas dari /30 (4 IP) ke /24
    #  (256 IP), mencakup seluruh subnet kantor 165.99.202.x
    # ─────────────────────────────────────────────────────────────

    # Dashboard AJAX endpoints — rate limited untuk mencegah overload
    location ~ ^/dashboard/(branch-hutang|branch-inter-debt|branch-inter-receivable|branch-cost-data|pending-list-data|batch-branch-stats)$ {
        allow 165.99.202.0/24;
        allow 10.0.0.0/8;
        allow 172.16.0.0/12;
        allow 192.168.0.0/16;
        deny all;

        limit_req zone=dashboard burst=10 nodelay;
        try_files $uri /index.php?$query_string;
    }

    location ~ ^/api/ {
        allow 165.99.202.0/24;   # Seluruh subnet kantor (sesuaikan jika perlu)
        allow 10.0.0.0/8;        # Docker internal
        allow 172.16.0.0/12;     # Docker bridge network
        allow 192.168.0.0/16;    # LAN lokal
        deny all;

        limit_req zone=api burst=20 nodelay;
        try_files $uri /index.php?$query_string;
    }

    # ─────────────────────────────────────────────────────────────
    #  LOGIN — Hanya IP kantor / jaringan internal
    # ─────────────────────────────────────────────────────────────

    location ~ ^/login {
        allow 165.99.202.0/24;
        allow 10.0.0.0/8;
        allow 172.16.0.0/12;
        allow 192.168.0.0/16;
        deny all;

        limit_req zone=login burst=3 nodelay;
        try_files $uri /index.php?$query_string;
    }

    # ─────────────────────────────────────────────────────────────
    #  APLIKASI UTAMA — Hanya IP kantor / jaringan internal
    # ─────────────────────────────────────────────────────────────

    location / {
        allow 165.99.202.0/24;
        allow 10.0.0.0/8;
        allow 172.16.0.0/12;
        allow 192.168.0.0/16;
        deny all;

        try_files $uri $uri/ /index.php?$query_string;
    }

    # ─────────────────────────────────────────────────────────────
    #  PHP-FPM HANDLER
    #
    #  ⚠️  WAJIB gunakan `internal;` — JANGAN pakai allow/deny!
    #
    #  Kenapa? try_files dari location manapun (termasuk webhook
    #  yang sudah bebas IP) akan meneruskan ke /index.php. Jika ada
    #  allow/deny di sini, IP n8n/Telegram akan ter-blokir walau
    #  sudah diizinkan di location asalnya (client IP tetap IP
    #  eksternal, bukan IP kantor).
    #
    #  `internal;` hanya memblokir akses LANGSUNG ke /index.php,
    #  tapi internal redirect dari try_files tetap diizinkan.
    # ─────────────────────────────────────────────────────────────

    location ~ \.php$ {
        internal;  # Blokir akses langsung; izinkan internal redirect dari try_files
        try_files $uri =404;
        fastcgi_split_path_info ^(.+\.php)(/.+)$;
        fastcgi_pass  php-fpm;
        fastcgi_index index.php;
        include       fastcgi_params;

        fastcgi_param SCRIPT_FILENAME $realpath_root$fastcgi_script_name;
        fastcgi_param DOCUMENT_ROOT   $realpath_root;
        fastcgi_param PATH_INFO       $fastcgi_path_info;

        # Forward headers dari proxy (Traefik/Cloudflare/Coolify)
        # Prioritaskan X-Forwarded-Host, fallback ke $host jika kosong
        set $real_host $http_x_forwarded_host;
        if ($real_host = "") {
            set $real_host $host;
        }
        fastcgi_param HTTP_HOST             $real_host;
        fastcgi_param HTTP_X_FORWARDED_HOST $real_host;

        fastcgi_param HTTP_X_FORWARDED_PROTO $http_x_forwarded_proto;
        fastcgi_param HTTP_X_FORWARDED_PORT  $http_x_forwarded_port;
        fastcgi_param HTTP_X_FORWARDED_FOR   $proxy_add_x_forwarded_for;
        fastcgi_param HTTP_X_REAL_IP         $remote_addr;

        # Force HTTPS karena Traefik/Cloudflare yang handle SSL termination
        set $fastcgi_https 'off';
        if ($http_x_forwarded_proto = 'https') {
            set $fastcgi_https 'on';
        }
        fastcgi_param HTTPS $fastcgi_https;

        # FastCGI optimizations
        fastcgi_buffers              16 16k;
        fastcgi_buffer_size          32k;
        fastcgi_busy_buffers_size    64k;
        fastcgi_temp_file_write_size 256k;
        fastcgi_connect_timeout      60;
        fastcgi_send_timeout         300;
        fastcgi_read_timeout         300;
        fastcgi_intercept_errors     off;
    }
}