# ═══════════════════════════════════════════════════════════════════
#  NGINX Configuration for Coolify (Internal Proxy)
#  Traefik handles SSL, domain routing, and HSTS
# ═══════════════════════════════════════════════════════════════════

# WebSocket upgrade map
map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}

# Rate limiting zones
limit_req_zone $binary_remote_addr zone=general:10m rate=10r/s;
limit_req_zone $binary_remote_addr zone=api:10m rate=60r/m;
limit_req_zone $binary_remote_addr zone=login:10m rate=5r/m;
limit_conn_zone $binary_remote_addr zone=addr:10m;

# Upstream PHP-FPM
upstream php-fpm {
    server app:9000;
    keepalive 32;
}

# Upstream Reverb (WebSocket) - force IPv4
# Gunakan 127.0.0.11 (Docker DNS) dengan ipv6=off untuk hindari IPv6 resolution
# upstream block dihapus - gunakan resolver + variable di location /app/ sebagai gantinya

server {
    listen 80;
    server_name _;

    # Ambil IP asli dari proxy depan, yaitu Traefik/Coolify
    real_ip_header X-Forwarded-For;
    real_ip_recursive on;

    # Percaya IP dari jaringan internal Docker/Coolify
    set_real_ip_from 10.0.0.0/8;
    set_real_ip_from 172.16.0.0/12;
    set_real_ip_from 192.168.0.0/16;
    
    root /var/www/public;   
    index index.php index.html;

    # Security Headers (Minimal, Traefik handles the rest)
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;
    
    # Client settings
    client_max_body_size 64M;
    client_body_buffer_size 128k;
    
    # Timeouts
    client_body_timeout 12;
    client_header_timeout 12;
    keepalive_timeout 15;
    send_timeout 10;
    
    # Connection limiting
    limit_conn addr 10;
    
    # Gzip compression
    gzip on;
    gzip_vary on;
    gzip_proxied any;
    gzip_comp_level 6;
    gzip_types text/plain text/css text/xml text/javascript application/json application/javascript application/xml+rss application/rss+xml font/truetype font/opentype application/vnd.ms-fontobject image/svg+xml application/xhtml+xml application/x-font-ttf application/x-font-opentype;
    
    # Logging
    access_log /var/log/nginx/access.log combined buffer=32k flush=5s;
    error_log /var/log/nginx/error.log warn;
    
    # Hide nginx version
    server_tokens off;
    
    # Static Files
    location ~* \.(jpg|jpeg|png|gif|ico|css|js|svg|woff|woff2|ttf|eot|webp|avif|map)$ {
        expires 1y;
        add_header Cache-Control "public, immutable";
        access_log off;
        try_files $uri =404;
    }
    
    # Storage
    location /storage/ {
        alias /var/www/storage/app/public/;
        expires 1y;
        add_header Cache-Control "public, max-age=31536000, immutable";
        access_log off;
        try_files $uri =404;
    }
    
    # Vite
    location /build/ {
        expires 1y;
        add_header Cache-Control "public, immutable";
        access_log off;
        try_files $uri =404;
    }
    
    # Deny Sensitive
    location ~ /\. {
        deny all;
        access_log off;
        log_not_found off;
    }
    
    # Rate Limited Endpoints
    # Login page dibatasi ke IP kantor (aplikasi internal)
    location ~ ^/login {
        allow 165.99.202.250/30;
        deny all;
        limit_req zone=login burst=3 nodelay;
        try_files $uri /index.php?$query_string;
    }
    
    # ─── EXCEPTIONS UNTUK WEBHOOK EXTERNAL ───
    # Webhook n8n dan Telegram harus bisa diakses dari public internet
    location ~ ^/api/(ai/auto-fill|ai/auto-fil|payment/verify|telegram/webhook) {
        # Override global restrictions - allow public access for webhooks
        allow all;
        limit_req zone=api burst=20 nodelay;
        try_files $uri /index.php?$query_string;
    }
    
    # ─── API Polling Status (untuk loading screen) ───
    # User yang sudah upload nota perlu polling status dari mana saja
    location ~ ^/api/ai/(auto-fill/status|ai-status)/ {
        allow all;
        limit_req zone=api burst=30 nodelay;
        try_files $uri /index.php?$query_string;
    }

    location ~ ^/api/ {
        # Restrict other API endpoints to office IP
        allow 165.99.202.250/30;
        deny all;
        limit_req zone=api burst=20 nodelay;
        try_files $uri /index.php?$query_string;
    }
    
    # WebSocket Proxy (Reverb) - dibatasi ke IP kantor
    # Koneksi WebSocket hanya dari browser pengguna internal
    location /app/ {
        allow 165.99.202.250/30;
        deny all;
        resolver 127.0.0.11 ipv6=off valid=10s;
        set $reverb_upstream http://reverb:8081;
        proxy_pass $reverb_upstream;
        proxy_http_version 1.1;
        
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_set_header Host $host;
        
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $http_x_forwarded_proto;

        proxy_set_header X-Forwarded-Host $host;
        
        proxy_connect_timeout 60s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;
        
        proxy_cache_bypass $http_upgrade;
        proxy_buffering off;
    }
    
    # Health Check (Optimized)
    location = /up {
        allow all;
        access_log off;
        return 200 "OK\n";
        add_header Content-Type text/plain;
    }

    location = /health {
        allow all;
        access_log off;
        return 200 "OK\n";
        add_header Content-Type text/plain;
    }
    
    # Broadcasting Authentication (untuk WebSocket)
    # Harus bisa diakses oleh authenticated users dari mana saja
    location = /broadcasting/auth {
        allow all;
        limit_req zone=api burst=10 nodelay;
        try_files $uri /index.php?$query_string;
    }
    
    # Main Laravel Application
    location / {
        # Restrict main application to office IP
        allow 165.99.202.250/30;
        deny all;
        try_files $uri $uri/ /index.php?$query_string;
    }
    
    # PHP-FPM Handler
    # ⚠️ PENTING: Gunakan `internal;` bukan allow/deny di sini!
    #
    # Kenapa? Karena allow/deny DI SINI akan memblokir internal redirect dari
    # webhook location (yang sudah punya allow all) ketika try_files mem-forward
    # ke /index.php. Client IP-nya tetap IP n8n, bukan IP kantor, sehingga
    # webhook yang sudah di-whitelist pun akan ter-blokir di sini.
    #
    # `internal;` solusinya: memblokir akses LANGSUNG ke /index.php dari siapapun
    # (termasuk non-kantor), tapi tetap mengizinkan internal redirect dari try_files
    # (sehingga webhook path yang sudah allow all tetap bisa mencapai PHP-FPM).
    location ~ \.php$ {
        internal;  # Hanya izinkan internal redirect (dari try_files), blokir akses langsung
        try_files $uri =404;
        fastcgi_split_path_info ^(.+\.php)(/.+)$;
        fastcgi_pass php-fpm;
        fastcgi_index index.php;
        include fastcgi_params;
        
        # Optimized SCRIPT_FILENAME
        fastcgi_param SCRIPT_FILENAME $realpath_root$fastcgi_script_name;
        fastcgi_param DOCUMENT_ROOT $realpath_root;
        fastcgi_param PATH_INFO $fastcgi_path_info;

        # Forward headers from proxy (Traefik/Cloudflare/Coolify)
        # We prioritize $http_x_forwarded_host but fallback to $host if empty
        set $real_host $http_x_forwarded_host;
        if ($real_host = "") {
            set $real_host $host;
        }
        fastcgi_param HTTP_HOST $real_host;
        fastcgi_param HTTP_X_FORWARDED_HOST $real_host;
        
        fastcgi_param HTTP_X_FORWARDED_PROTO $http_x_forwarded_proto;
        fastcgi_param HTTP_X_FORWARDED_PORT $http_x_forwarded_port;
        fastcgi_param HTTP_X_FORWARDED_FOR $proxy_add_x_forwarded_for;
        fastcgi_param HTTP_X_REAL_IP $remote_addr;

        # Force HTTPS since Traefik/Cloudflare handles SSL
        set $fastcgi_https 'off';
        if ($http_x_forwarded_proto = 'https') {
            set $fastcgi_https 'on';
        }
        fastcgi_param HTTPS $fastcgi_https;
        
        # FastCGI optimizations
        fastcgi_buffers 16 16k;
        fastcgi_buffer_size 32k;
        fastcgi_busy_buffers_size 64k;
        fastcgi_temp_file_write_size 256k;
        fastcgi_connect_timeout 60;
        fastcgi_send_timeout 300;
        fastcgi_read_timeout 300;
        fastcgi_intercept_errors off;
    }
}